# MiniTrack — environment template
#
#   cp .env.example .env
#   uvicorn app.main:app --reload --env-file .env
#
# Every setting is optional and has a default (see app/core/config.py), but
# MINITRACK_API_KEYS is effectively required: without it every /tasks* request
# returns 401. Settings are read once and cached (@lru_cache on get_settings),
# so changing any of these needs a server restart.


# Comma-separated list of valid API keys, sent by clients as the `X-API-Key`
# header. Multiple keys are supported: MINITRACK_API_KEYS=key-a,key-b
# Default: empty -> every /tasks* request returns 401 (never fails open).
MINITRACK_API_KEYS=demo-key-123


# Comma-separated list of browser origins allowed to call this API.
#
# REQUIRED FOR THE REACT FRONTEND. CORSMiddleware is only installed when this is
# non-empty (app/main.py). Because the X-API-Key header makes every request
# "non-simple", even GET /tasks triggers an OPTIONS preflight -- so with this
# unset, the SPA fails on its very first call with an opaque network error.
#
# Note http://localhost:5173 and http://127.0.0.1:5173 are DISTINCT origins to a
# browser; list both so either dev-server URL works.
# Default: empty -> CORS middleware not installed at all.
MINITRACK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# Where the SQLite file lives. Created on first run; safe to delete to reset.
# Default: <repo root>/minitrack.db
# MINITRACK_DB_PATH=/absolute/path/to/minitrack.db


# Root log level: DEBUG | INFO | WARNING | ERROR.
# Default: INFO
# MINITRACK_LOG_LEVEL=INFO


# Prefix every route is mounted under, e.g. "/api/v1" -> /api/v1/tasks.
# Leave empty to serve /health and /tasks at the root.
# Default: "" (empty)
# MINITRACK_API_PREFIX=
