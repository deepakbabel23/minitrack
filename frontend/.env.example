# MiniTrack frontend configuration (safe to commit — contains NO secrets).
#
# Copy this file to `.env` and adjust if your backend runs elsewhere:
#   cp .env.example .env
#
# The base URL of the FastAPI backend. Vite exposes every VITE_* variable to the
# browser bundle, so ONLY put non-secret values here.
VITE_API_BASE_URL=http://127.0.0.1:8000

# NOTE: There is deliberately no VITE_API_KEY here. The MiniTrack X-API-Key is a
# secret; anything in a VITE_* variable is baked into the shipped JavaScript and
# readable by anyone. The key is entered at runtime on the /connect screen and
# kept in memory instead. See frontend/README.md for the reasoning.
