# Copy to .env and adjust if the backend runs somewhere else.
#
#   cp .env.example .env
#
# There is deliberately NO VITE_API_KEY here. Everything in a VITE_* variable is
# inlined into the client bundle at build time and shipped to every visitor, so
# it is not a secret. The MiniTrack API key is entered on the /connect screen and
# held in memory for the session.
#
# The backend must allow this origin: set MINITRACK_CORS_ORIGINS in the root
# .env, or every request fails its preflight.

VITE_API_BASE_URL=http://127.0.0.1:8000
